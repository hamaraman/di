---
import { SITE } from '../../astro.config.mjs';

interface Props {
  title: string;
  description: string;
  /** 글 상세일 때만: 발행/수정일, OG 타입을 article 로 */
  pubDate?: Date;
  updatedDate?: Date;
  type?: 'website' | 'article';
  tags?: string[];
  /** 공유 미리보기 이미지 경로(사이트 루트 기준). 미지정 시 기본 OG 이미지 사용 */
  image?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  type = 'website',
  tags = [],
  image = '/og/default.png',
} = Astro.props;

// canonical URL — 중복 콘텐츠 방지, 구글/네이버 모두 중요
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
// OG 이미지 절대 URL — 카카오/페북/네이버는 절대경로를 요구
const ogImage = new URL(image, SITE.url).toString();
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;

// 구조화 데이터 (JSON-LD) — 구글 리치 결과에 반영
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: pubDate?.toISOString(),
        dateModified: (updatedDate ?? pubDate)?.toISOString(),
        author: { '@type': 'Person', name: SITE.author },
        keywords: tags.join(', '),
        mainEntityOfPage: canonical,
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.title,
        description: SITE.description,
        url: SITE.url,
      };
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- 파비콘 -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 검색엔진 소유확인 -->
    <meta name="google-site-verification" content="zzjx7eGYWw4LjTTM9dZs6pe4UpySG3WaLiv17juJXeA" />
    <meta name="naver-site-verification" content="4e04a96d19a63ff8826ffb7cf186259f4082dcb3" />

    <!-- Open Graph (카카오톡·페이스북·네이버 공유 미리보기) -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X 카드 -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href="/rss.xml"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header>
      <a href="/" class="site-title">{SITE.title}</a>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <nav class="footer-nav">
        <a href="/about/">소개</a>
        <a href="/contact/">문의</a>
        <a href="/privacy/">개인정보처리방침</a>
      </nav>
      <p>© {new Date().getFullYear()} {SITE.author}</p>
    </footer>

    <style is:global>
      :root {
        --w: 720px;
        --fg: #1a1a1a;
        --muted: #666;
        --accent: #2563eb;
        --card: #f1f6ff;
        --line: #e5e7eb;
        --code-bg: #f1f5f9;
        --chip: #f1f5f9;
        --chip-fg: #475569;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, 'Segoe UI', 'Malgun Gothic', sans-serif;
        color: var(--fg);
        line-height: 1.7;
      }
      header, main, footer { max-width: var(--w); margin: 0 auto; padding: 1rem; }
      header { border-bottom: 1px solid #eee; }
      .site-title { font-weight: 700; font-size: 1.25rem; text-decoration: none; color: var(--fg); }
      main { padding-block: 2rem; }
      a { color: var(--accent); }
      h1 { line-height: 1.3; }
      article :is(h2, h3) { margin-top: 2rem; }
      /* 소제목: 스캔하기 좋게 액센트 바 */
      article h2 { border-left: 4px solid var(--accent); padding-left: .6rem; }
      /* 콜아웃(주의·참고): blockquote 를 박스로 */
      article blockquote {
        margin: 1.5rem 0; padding: .85rem 1.1rem;
        background: var(--card); border-left: 4px solid var(--accent);
        border-radius: 0 8px 8px 0;
      }
      article blockquote > :first-child { margin-top: 0; }
      article blockquote > :last-child { margin-bottom: 0; }
      /* 단계: 번호 뱃지 */
      article ol { counter-reset: step; list-style: none; padding-left: 0; }
      article ol > li {
        counter-increment: step; position: relative;
        padding-left: 2.5rem; margin: .6rem 0;
      }
      article ol > li::before {
        content: counter(step); position: absolute; left: 0; top: .05rem;
        width: 1.7rem; height: 1.7rem; border-radius: 50%;
        background: #2563eb; color: #fff; font-weight: 700; font-size: .9rem;
        display: grid; place-items: center;
      }
      article ul > li::marker { color: var(--accent); }
      /* 코드 */
      article :not(pre) > code {
        background: var(--code-bg); padding: .1rem .35rem;
        border-radius: 4px; font-size: .9em;
      }
      article pre {
        background: var(--code-bg); color: var(--fg);
        padding: .9rem 1.1rem; border-radius: 8px; overflow-x: auto;
        border: 1px solid var(--line); font-size: .92rem; line-height: 1.5;
      }
      article pre code { background: none; padding: 0; }
      /* 표 */
      article table { border-collapse: collapse; width: 100%; margin: 1.5rem 0; font-size: .95rem; }
      article :is(th, td) { border: 1px solid var(--line); padding: .5rem .7rem; text-align: left; }
      article th { background: var(--card); }
      /* 인라인 SVG 도식 */
      article svg { max-width: 100%; height: auto; display: block; margin: 1.5rem auto; }
      /* 태그 칩 */
      .tag-chip {
        display: inline-block; font-size: .8rem; color: var(--chip-fg);
        background: var(--chip); border-radius: 999px;
        padding: .15rem .65rem; margin: 0 .4rem .4rem 0;
      }
      footer { color: var(--muted); border-top: 1px solid #eee; font-size: .9rem; }
      .footer-nav { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: .5rem; }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #eaeaea; --muted: #999; --accent: #6ea8fe;
          --card: #172033; --line: #2a2a2a; --code-bg: #1e293b;
          --chip: #1e293b; --chip-fg: #94a3b8;
        }
        body { background: #121212; }
        header, footer { border-color: #2a2a2a; }
      }
    </style>
  </body>
</html>
